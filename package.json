{
  "name": "fiduciary",
  "version": "0.1.0",
  "description": "AI-powered invoice factoring with competing autonomous agents",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next",
    "seed": "tsx scripts/seed-demo.ts",
    "deploy:contracts": "tsx scripts/deploy-contracts.ts",
    "setup:hedera": "tsx scripts/setup-hedera.ts",
    "test:llm-bid": "tsx scripts/test-llm-bid.ts",
    "test:hedera-schedule": "tsx scripts/test-hedera-schedule.ts",
    "verify:arc-deploy": "tsx scripts/verify-arc-deploy.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.0"
}

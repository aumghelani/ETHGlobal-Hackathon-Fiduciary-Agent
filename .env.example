# ============================================
# FIDUCIARY — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local
# ============================================

# ---------------------------------------------
# STORE (serverless persistence)
# Local dev works WITHOUT these (in-memory fallback). REQUIRED on Vercel —
# serverless functions don't share process memory, so demo state must live in
# a shared store. Free Upstash Redis: https://console.upstash.com (create a
# Redis DB → copy the REST URL + token).
# ---------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------
# HEDERA (testnet)
# Get credentials from https://portal.hedera.com
# ---------------------------------------------
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...
# Treasury account for invoice tokens (same as operator in MVP)
HEDERA_TREASURY_ID=0.0.XXXXXXX
HEDERA_TREASURY_KEY=302e020100300506032b657004220420...

# Optional: pre-created HCS topic for invoice hash audit log
# If not set, will be created on first run
HEDERA_HCS_TOPIC_ID=

# ---------------------------------------------
# ARC (Circle's testnet) — gas is paid in USDC, fund deployer from Circle faucet
# RPC/chain ID/USDC verified from docs.arc.io + chainlist (chain 5042002)
# Faucet: https://faucet.circle.com (select Arc Testnet) — explorer: https://testnet.arcscan.app
# ---------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_PRIVATE_KEY=0x...
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
# Deployed contract addresses (filled in after deployment)
ARC_INVOICE_POOL_FACTORY=
ARC_DISTRIBUTION_EXECUTOR=

# Demo identities for InvoicePool deployment
FREELANCER_ADDRESS=
AGENT_ADDRESS=

# ---------------------------------------------
# ANTHROPIC (for AI agents)
# Get key from https://console.anthropic.com
# Requires API credits — separate from a Claude Pro/Max subscription
# ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ---------------------------------------------
# UNLINK (privacy layer)
# Verify exact var names from Unlink docs
# ---------------------------------------------
UNLINK_API_KEY=
UNLINK_APP_ID=
UNLINK_RPC_URL=
UNLINK_RELAYER_URL=
# Private payout custodian (Track E): where the aggregate private (Unlink) position is
# withdrawn to at settlement. Defaults to FREELANCER_ADDRESS if unset. Not per-investor
# (privateDeposits store no recipient) — see ADR-024.
PRIVATE_PAYOUT_ADDRESS=

# ---------------------------------------------
# SPONSOR CANDIDATES (isolated modules, NOT wired in — user decides)
# ---------------------------------------------

# WORLD ID (proof-of-personhood, THREAT_MODEL Layer 1) — lib/worldid.ts + /upload gate
# USER-REQUIRED: create a Staging app at developer.worldcoin.org → App ID + action.
# See docs/WORLDID_RECON.md. WORLDID_VERIFY_URL overrides the endpoint for the v4 path.
# Server-side (backend verify):
WORLDID_APP_ID=
WORLDID_ACTION=
WORLDID_VERIFY_URL=
# Client-side (the IDKit widget on /upload — must be NEXT_PUBLIC_, same values):
NEXT_PUBLIC_WLD_APP_ID=
NEXT_PUBLIC_WLD_ACTION=
# World ID 4.0 self-managed: RP id + the SECRET signing key (signs each rp_context).
# WORLDID_RP_ID activates the gate; WORLDID_SIGNING_KEY is required to sign (keep secret).
WORLDID_RP_ID=
WORLDID_SIGNING_KEY=
# Demo escape hatch (default OFF). Set BOTH to "true" to walk upload→auction WITHOUT a
# real World ID account (no Orb/World App needed). The gate stays real otherwise.
DEMO_BYPASS_WORLDID=
NEXT_PUBLIC_DEMO_BYPASS_WORLDID=

# DYNAMIC wallet/auth (login + connected-wallet funding) — free Sandbox env ID from
# app.dynamic.xyz (Settings → Embedded Wallets ON for embedded MPC wallets). Without it the
# app degrades: the Sign-in button is hidden and funding stays server-side. Arc is
# registered as a custom EVM network in components/DynamicProvider.tsx.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# INVESTOR KYC / accreditation gate (Part 2) — lib/kyc.ts (mock-with-seam, default OFF).
# KYC_ENABLED=true turns the gate on (server); NEXT_PUBLIC_KYC_ENABLED mirrors it (client UI).
# DEMO_BYPASS_KYC=true short-circuits the check even when enabled (passes). Today the check
# is a deterministic mock; swap a real provider behind verifyInvestor() to go live.
KYC_ENABLED=
NEXT_PUBLIC_KYC_ENABLED=
DEMO_BYPASS_KYC=

# BLINK (@swype-org/deposit) — lib/blink.ts (STUB; Blink is a DEPOSIT sdk, no fiat off-ramp,
# and does NOT support Arc — sandbox is Base Sepolia only). See docs/BLINK_RECON.md.
# Sandbox auto-approves; no API key, auth is a self-generated ECDSA P-256 keypair + merchantId.
BLINK_MERCHANT_ID=
BLINK_SIGNER_PRIVATE_KEY=

# CIRCLE AGENT WALLET (@circle-fin/developer-controlled-wallets) — lib/circleAgentWallet.ts
# USER-REQUIRED: separate Circle Developer Console signup → API key + registered entity secret.
# Arc IS supported (ARC-TESTNET). See docs/CIRCLE_AGENT_RECON.md.
CIRCLE_AGENT_API_KEY=
CIRCLE_AGENT_ENTITY_SECRET=

# ---------------------------------------------
# AGENT ACCOUNTS
# Pre-fund these on testnet for the demo
# ---------------------------------------------
# Veteran agent's accounts
VETERAN_AGENT_HEDERA_ID=0.0.XXXXXXX
VETERAN_AGENT_HEDERA_KEY=302e020100300506032b657004220420...
VETERAN_AGENT_ARC_ADDRESS=0x...

# Newbie agent's accounts
NEWBIE_AGENT_HEDERA_ID=0.0.XXXXXXX
NEWBIE_AGENT_HEDERA_KEY=302e020100300506032b657004220420...
NEWBIE_AGENT_ARC_ADDRESS=0x...

# ---------------------------------------------
# DEMO IDENTITIES (hardcoded for MVP)
# ---------------------------------------------
# Maria (freelancer)
DEMO_MARIA_ARC_ADDRESS=0x...
DEMO_MARIA_HEDERA_ID=0.0.XXXXXXX

# BigCorp (client)
DEMO_BIGCORP_ARC_ADDRESS=0x...

# ---------------------------------------------
# FRONTEND
# ---------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DEMO=true
NEXT_PUBLIC_APP_NAME=Fiduciary

# ---------------------------------------------
# BACKEND
# ---------------------------------------------
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
